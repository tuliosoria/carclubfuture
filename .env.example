# Required for runtime (DynamoDB)
AWS_REGION=us-east-1
DYNAMODB_TABLE=carclubfuture-cache

# Sync scripts
OLDCARSDATA_API_KEY=
CARQUERY_BASE_URL=

# ML runtime
CARS_ML_MODEL_SOURCE=auto
CARS_ML_PUBLISH_ENABLED=false
CARS_ML_OUTPUT_DIR=

# Optional owned-data exports
OWNED_DATA_ASSET_BUCKET=
OWNED_DATA_ASSET_PREFIX=owned-data

# Legal / contact (rendered on legal pages)
LEGAL_OPERATOR_NAME=CarClubFuture
LEGAL_CONTACT_EMAIL=hello@carclubfuture.com
PRIVACY_REQUEST_EMAIL=privacy@carclubfuture.com
LEGAL_BUSINESS_ADDRESS=
LEGAL_CONTACT_URL=
