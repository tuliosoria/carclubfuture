# OldCarsData API (required for sync:oldcarsdata)
# Free tier: 10 requests/MONTH, last 14 days of auctions only
OLDCARSDATA_API_KEY=

# Bring a Trailer scrape (optional; default off)
# Set to "1" to enable; respects polite 1 req/3s throttle
BAT_SCRAPE_ENABLED=

# CarAPI (optional; enriches bulk catalog with trim specs)
CARAPI_KEY=

# AWS / DynamoDB (required for tiered cache; defaults shown)
AWS_REGION=us-east-1
DYNAMODB_TABLE=carclubfuture-cache

# AWS credentials — pick one auth method:
# 1) IAM role (preferred in production; leave keys unset)
# 2) Static keys (development only)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Sync scripts (misc)
CARQUERY_BASE_URL=

# ML runtime
CARS_ML_MODEL_SOURCE=auto
CARS_ML_PUBLISH_ENABLED=false
CARS_ML_OUTPUT_DIR=

# Optional owned-data exports
OWNED_DATA_ASSET_BUCKET=
OWNED_DATA_ASSET_PREFIX=owned-data

# Legal / contact (rendered on legal pages)
LEGAL_OPERATOR_NAME=CarClubFuture
LEGAL_CONTACT_EMAIL=hello@carclubfuture.com
PRIVACY_REQUEST_EMAIL=privacy@carclubfuture.com
LEGAL_BUSINESS_ADDRESS=
LEGAL_CONTACT_URL=
