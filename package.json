{
  "name": "carclubfuture",
  "version": "0.1.0",
  "private": true,
  "description": "Collector Car Value Forecasting & ROI Engine",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "verify:lint": "eslint .",
    "verify:build": "next build",
    "verify:scripts": "node scripts/verify-scripts.mjs",
    "verify:app": "npm run verify:lint && npm run verify:build",
    "verify": "npm run verify:lint && npm run verify:build && npm run verify:scripts",
    "hooks:install": "git config core.hooksPath .githooks",
    "sync:cars:catalog": "python3 scripts/sync_cars_catalog.py",
    "sync:cars:segments": "node scripts/build-segment-catalog.mjs",
    "sync:oldcarsdata": "node scripts/sync-oldcarsdata-prices.mjs",
    "sync:images": "node scripts/mirror-car-images.mjs",
    "sync:oldcarsdata:bulk": "node scripts/sync-oldcarsdata-bulk.mjs",
    "sync:trends": "node scripts/sync-trends.mjs",
    "train:cars-ml": "python3 scripts/train_cars_ml.py",
    "retrain:cars-ml": "python3 scripts/retrain_cars_ml.py",
    "backfill:cars:catalog": "node scripts/backfill-cars-catalog.mjs",
    "ingest:cars:catalog": "node scripts/ingest-cars-catalog-bulk.mjs --start-year=1950 --end-year=2024 --output=src/lib/data/cars-ml/cars-catalog-bulk.json --checkpoint=scripts/output/ingest-checkpoint.json",
    "build:community": "node scripts/build-community-score.mjs",
    "sync:bat:history": "node scripts/sync-bat-history.mjs",
    "build:price:aggregates": "node scripts/build-price-aggregates.mjs --output=src/lib/data/cars-ml/price-aggregates.json",
    "build:brand": "node scripts/build-brand-features.mjs --output=src/lib/data/cars-ml/brand-features.json",
    "sync:macro": "node scripts/sync-macro-features.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.658.0",
    "@aws-sdk/client-s3": "^3.658.0",
    "@aws-sdk/lib-dynamodb": "^3.658.0",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "google-trends-api": "^4.9.2",
    "lucide-react": "^0.468.0",
    "next": "^16.2.6",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.0",
    "recharts": "^2.13.3",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "^16.2.6",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.22.0",
    "typescript": "^5.7.0"
  }
}
